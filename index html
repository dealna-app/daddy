<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Dealna – أفضل العروض في المغرب</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --red: #C8102E;
    --green: #006233;
    --gold: #E8A020;
    --cream: #FAF6EE;
    --dark: #1A1208;
    --mid: #5C4A2A;
    --light-gold: #FDF3DC;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }
  body { font-family: 'DM Sans', sans-serif; background: var(--cream); color: var(--dark); overflow-x: hidden; }

  /* ── NAV ── */
  nav {
    position: sticky; top: 0; z-index: 200;
    background: var(--dark);
    display: flex; align-items: center; justify-content: space-between;
    padding: 0 5vw; height: 64px;
    border-bottom: 3px solid var(--gold);
  }
  .logo { font-family: 'Playfair Display', serif; font-size: 1.7rem; font-weight: 900; color: var(--cream); letter-spacing: -0.5px; cursor: pointer; }
  .logo span { color: var(--gold); }
  .nav-links { display: flex; gap: 2rem; list-style: none; align-items: center; }
  .nav-links a { color: #ccc; text-decoration: none; font-size: 0.9rem; font-weight: 500; letter-spacing: 0.04em; text-transform: uppercase; transition: color 0.2s; cursor: pointer; }
  .nav-links a:hover { color: var(--gold); }
  .nav-cta { background: var(--red) !important; color: #fff !important; padding: 0.45rem 1.2rem; border-radius: 4px; font-weight: 600 !important; }
  .nav-cta:hover { background: #a50e26 !important; }
  .nav-user { display: flex; align-items: center; gap: 0.6rem; color: var(--gold) !important; }
  .nav-user .avatar { width: 30px; height: 30px; border-radius: 50%; background: var(--gold); color: var(--dark); display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 0.8rem; }

  /* ── HERO ── */
  .hero { position: relative; background: var(--dark); overflow: hidden; padding: 80px 5vw 90px; display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; }
  .hero::before { content: ''; position: absolute; inset: 0; background: radial-gradient(ellipse at 70% 50%, rgba(200,16,46,0.18) 0%, transparent 60%), radial-gradient(ellipse at 20% 80%, rgba(0,98,51,0.15) 0%, transparent 50%); }
  .hero::after { content: ''; position: absolute; right: 0; top: 0; bottom: 0; width: 48%; opacity: 0.05; background-image: repeating-linear-gradient(45deg, var(--gold) 0, var(--gold) 1px, transparent 0, transparent 50%), repeating-linear-gradient(-45deg, var(--gold) 0, var(--gold) 1px, transparent 0, transparent 50%); background-size: 20px 20px; }
  .hero-text { position: relative; z-index: 2; }
  .hero-badge { display: inline-flex; align-items: center; gap: 0.5rem; background: rgba(232,160,32,0.15); border: 1px solid rgba(232,160,32,0.4); color: var(--gold); padding: 0.3rem 0.9rem; border-radius: 99px; font-size: 0.78rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 1.4rem; animation: fadeUp 0.6s ease both; }
  h1 { font-family: 'Playfair Display', serif; font-size: clamp(2.8rem, 5vw, 4.2rem); font-weight: 900; color: var(--cream); line-height: 1.08; margin-bottom: 1.2rem; animation: fadeUp 0.6s 0.1s ease both; }
  h1 em { color: var(--gold); font-style: normal; }
  .hero-sub { color: #9e8e78; font-size: 1.05rem; line-height: 1.65; max-width: 420px; margin-bottom: 2rem; animation: fadeUp 0.6s 0.2s ease both; }
  .hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; animation: fadeUp 0.6s 0.3s ease both; }
  .btn-primary { background: var(--red); color: #fff; padding: 0.85rem 2rem; border-radius: 6px; font-weight: 600; font-size: 0.95rem; text-decoration: none; border: none; cursor: pointer; transition: transform 0.15s, box-shadow 0.15s; box-shadow: 0 4px 20px rgba(200,16,46,0.4); font-family: 'DM Sans', sans-serif; }
  .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 8px 28px rgba(200,16,46,0.5); }
  .btn-secondary { background: transparent; color: var(--cream); padding: 0.85rem 2rem; border-radius: 6px; font-weight: 500; font-size: 0.95rem; text-decoration: none; border: 1.5px solid rgba(255,255,255,0.2); transition: border-color 0.2s, background 0.2s; cursor: pointer; font-family: 'DM Sans', sans-serif; }
  .btn-secondary:hover { border-color: var(--gold); background: rgba(232,160,32,0.08); }
  .hero-stats { position: relative; z-index: 2; display: grid; grid-template-columns: 1fr 1fr; gap: 1.2rem; animation: fadeUp 0.6s 0.4s ease both; }
  .stat-card { background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08); border-radius: 12px; padding: 1.5rem; backdrop-filter: blur(8px); transition: border-color 0.2s, background 0.2s; }
  .stat-card:hover { border-color: rgba(232,160,32,0.35); background: rgba(232,160,32,0.05); }
  .stat-card .num { font-family: 'Playfair Display', serif; font-size: 2.2rem; font-weight: 700; color: var(--gold); line-height: 1; }
  .stat-card .label { color: #7a6a58; font-size: 0.82rem; margin-top: 0.3rem; }

  /* ── SEARCH ── */
  .search-bar { background: var(--dark); padding: 0 5vw 2rem; }
  .search-inner { max-width: 700px; margin: 0 auto; display: flex; background: rgba(255,255,255,0.05); border: 1.5px solid rgba(232,160,32,0.3); border-radius: 10px; overflow: hidden; transition: border-color 0.2s; }
  .search-inner:focus-within { border-color: var(--gold); }
  .search-inner input { flex: 1; background: transparent; border: none; outline: none; padding: 1rem 1.2rem; color: var(--cream); font-family: 'DM Sans', sans-serif; font-size: 0.95rem; }
  .search-inner input::placeholder { color: #6a5c48; }
  .search-inner button { background: var(--gold); color: var(--dark); border: none; padding: 0 1.5rem; font-weight: 700; font-size: 0.9rem; cursor: pointer; letter-spacing: 0.04em; text-transform: uppercase; transition: background 0.2s; font-family: 'DM Sans', sans-serif; }
  .search-inner button:hover { background: #d4921c; }

  /* ── SECTIONS ── */
  section { padding: 60px 5vw; }
  section + section { padding-top: 0; }
  .section-header { display: flex; align-items: baseline; justify-content: space-between; margin-bottom: 2rem; }
  .section-title { font-family: 'Playfair Display', serif; font-size: 1.8rem; font-weight: 700; color: var(--dark); }
  .section-title span { color: var(--red); }
  .see-all { color: var(--red); font-weight: 600; text-decoration: none; font-size: 0.88rem; letter-spacing: 0.04em; border-bottom: 1px solid transparent; transition: border-color 0.2s; cursor: pointer; }
  .see-all:hover { border-color: var(--red); }

  /* ── CATEGORIES ── */
  .categories { background: var(--light-gold); }
  .cat-grid { display: flex; gap: 1rem; flex-wrap: wrap; }
  .cat-chip { display: flex; align-items: center; gap: 0.5rem; background: #fff; border: 1.5px solid #e8dcc8; padding: 0.55rem 1.1rem; border-radius: 99px; cursor: pointer; font-size: 0.88rem; font-weight: 500; color: var(--mid); transition: all 0.2s; text-decoration: none; }
  .cat-chip:hover, .cat-chip.active { background: var(--dark); border-color: var(--dark); color: var(--gold); }
  .cat-chip .icon { font-size: 1.1rem; }

  /* ── DEAL CARDS ── */
  .deals-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.4rem; }
  .deal-card { background: #fff; border-radius: 14px; overflow: hidden; border: 1.5px solid #ede4d4; transition: transform 0.2s, box-shadow 0.2s, border-color 0.2s; position: relative; }
  .deal-card:hover { transform: translateY(-4px); box-shadow: 0 12px 40px rgba(26,18,8,0.12); border-color: var(--gold); }
  .deal-badge { position: absolute; top: 12px; left: 12px; background: var(--red); color: #fff; padding: 0.2rem 0.6rem; border-radius: 4px; font-size: 0.72rem; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; }
  .deal-badge.verified { background: var(--green); }
  .deal-badge.hot { background: #ff6b1a; }
  .deal-img { height: 130px; display: flex; align-items: center; justify-content: center; font-size: 3rem; background: linear-gradient(135deg, #faf0e0, #f5e8cc); }
  .deal-body { padding: 1.1rem; }
  .deal-store { font-size: 0.72rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: var(--gold); margin-bottom: 0.3rem; }
  .deal-title { font-weight: 600; font-size: 0.95rem; color: var(--dark); line-height: 1.35; margin-bottom: 0.8rem; }
  .deal-code-row { display: flex; align-items: center; gap: 0.6rem; margin-bottom: 0.8rem; }
  .deal-code { flex: 1; background: var(--light-gold); border: 1.5px dashed #c9aa72; border-radius: 6px; padding: 0.4rem 0.7rem; font-family: 'Courier New', monospace; font-weight: 700; font-size: 0.9rem; color: var(--mid); letter-spacing: 0.05em; text-align: center; }
  .copy-btn { background: var(--dark); color: var(--gold); border: none; padding: 0.4rem 0.8rem; border-radius: 6px; font-size: 0.78rem; font-weight: 700; cursor: pointer; transition: background 0.2s; white-space: nowrap; font-family: 'DM Sans', sans-serif; }
  .copy-btn:hover { background: #2e2010; }
  .copy-btn.copied { background: var(--green); color: #fff; }
  .deal-footer { display: flex; align-items: center; justify-content: space-between; font-size: 0.78rem; color: #9e8e78; }
  .deal-savings { font-weight: 700; color: var(--red); font-size: 0.88rem; }
  .expiry { display: flex; align-items: center; gap: 0.3rem; }
  .expiry .dot { width: 6px; height: 6px; border-radius: 50%; background: #22c55e; }
  .expiry .dot.soon { background: #f59e0b; }
  .expiry .dot.expired { background: #ef4444; }

  /* save button on card */
  .save-btn { position: absolute; top: 12px; right: 12px; background: rgba(26,18,8,0.6); border: none; color: #ccc; width: 32px; height: 32px; border-radius: 50%; cursor: pointer; font-size: 1rem; display: flex; align-items: center; justify-content: center; transition: all 0.2s; backdrop-filter: blur(4px); }
  .save-btn:hover, .save-btn.saved { color: var(--gold); background: rgba(26,18,8,0.85); }

  /* ── LOAD MORE ── */
  .load-more-wrap { text-align: center; margin-top: 2rem; }

  /* ── STORES ── */
  .featured-section { background: var(--dark); }
  .featured-section .section-title { color: var(--cream); }
  .store-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); gap: 1rem; }
  .store-card { background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.08); border-radius: 12px; padding: 1.5rem 1rem; text-align: center; cursor: pointer; transition: all 0.2s; text-decoration: none; }
  .store-card:hover { background: rgba(232,160,32,0.1); border-color: rgba(232,160,32,0.4); transform: translateY(-2px); }
  .store-card .store-icon { font-size: 2rem; margin-bottom: 0.6rem; }
  .store-card .store-name { color: #ccc; font-size: 0.82rem; font-weight: 500; }
  .store-card .store-count { color: var(--gold); font-size: 0.72rem; margin-top: 0.2rem; }

  /* ── HOW IT WORKS ── */
  .how-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 2rem; }
  .how-step { text-align: center; padding: 2rem 1.5rem; border-radius: 16px; background: #fff; border: 1.5px solid #ede4d4; transition: border-color 0.2s; }
  .how-step:hover { border-color: var(--gold); }
  .step-num { width: 48px; height: 48px; border-radius: 50%; background: var(--dark); color: var(--gold); display: flex; align-items: center; justify-content: center; font-family: 'Playfair Display', serif; font-size: 1.2rem; font-weight: 700; margin: 0 auto 1rem; }
  .how-step h3 { font-size: 1rem; font-weight: 700; margin-bottom: 0.5rem; }
  .how-step p { font-size: 0.87rem; color: #6a5c48; line-height: 1.6; }

  /* ── NEWSLETTER ── */
  .newsletter { background: var(--red); position: relative; overflow: hidden; }
  .newsletter::before { content: ''; position: absolute; inset: 0; background: repeating-linear-gradient(-45deg, rgba(255,255,255,0.03) 0, rgba(255,255,255,0.03) 1px, transparent 0, transparent 20px); }
  .newsletter-inner { position: relative; max-width: 580px; margin: 0 auto; text-align: center; }
  .newsletter h2 { font-family: 'Playfair Display', serif; font-size: 2.2rem; font-weight: 900; color: #fff; margin-bottom: 0.8rem; }
  .newsletter p { color: rgba(255,255,255,0.8); margin-bottom: 1.5rem; }
  .nl-form { display: flex; border-radius: 8px; overflow: hidden; background: #fff; box-shadow: 0 8px 30px rgba(0,0,0,0.25); }
  .nl-form input { flex: 1; border: none; outline: none; padding: 0.9rem 1.2rem; font-family: 'DM Sans', sans-serif; font-size: 0.92rem; color: var(--dark); }
  .nl-form button { background: var(--dark); color: var(--gold); border: none; padding: 0 1.4rem; font-weight: 700; font-size: 0.88rem; cursor: pointer; letter-spacing: 0.04em; text-transform: uppercase; transition: background 0.2s; white-space: nowrap; font-family: 'DM Sans', sans-serif; }
  .nl-form button:hover { background: #2e2010; }

  /* ── FOOTER ── */
  footer { background: #110e07; color: #7a6a58; padding: 40px 5vw 24px; }
  .footer-grid { display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 3rem; margin-bottom: 2rem; }
  .footer-logo { font-family: 'Playfair Display', serif; font-size: 1.4rem; font-weight: 900; color: var(--cream); margin-bottom: 0.8rem; }
  .footer-logo span { color: var(--gold); }
  footer p { font-size: 0.85rem; line-height: 1.65; }
  .footer-col h4 { color: var(--cream); font-size: 0.82rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 1rem; }
  .footer-col ul { list-style: none; display: flex; flex-direction: column; gap: 0.5rem; }
  .footer-col a { color: #7a6a58; text-decoration: none; font-size: 0.85rem; transition: color 0.2s; }
  .footer-col a:hover { color: var(--gold); }
  .footer-bottom { border-top: 1px solid rgba(255,255,255,0.06); padding-top: 1.4rem; display: flex; justify-content: space-between; align-items: center; font-size: 0.8rem; }
  .ornament { text-align: center; font-size: 1.5rem; color: var(--gold); opacity: 0.4; letter-spacing: 0.5rem; padding: 0.5rem 0; }

  /* ── MODAL ── */
  .modal-overlay { position: fixed; inset: 0; background: rgba(26,18,8,0.75); z-index: 500; display: flex; align-items: center; justify-content: center; padding: 1rem; opacity: 0; pointer-events: none; transition: opacity 0.25s; backdrop-filter: blur(4px); }
  .modal-overlay.open { opacity: 1; pointer-events: all; }
  .modal { background: #fff; border-radius: 16px; padding: 2.5rem; width: 100%; max-width: 440px; position: relative; transform: translateY(20px); transition: transform 0.25s; }
  .modal-overlay.open .modal { transform: translateY(0); }
  .modal-close { position: absolute; top: 1rem; right: 1rem; background: none; border: none; font-size: 1.4rem; cursor: pointer; color: #9e8e78; }
  .modal h2 { font-family: 'Playfair Display', serif; font-size: 1.6rem; margin-bottom: 0.3rem; }
  .modal p { color: #6a5c48; font-size: 0.9rem; margin-bottom: 1.5rem; }
  .modal-tabs { display: flex; gap: 0; border-radius: 8px; overflow: hidden; border: 1.5px solid #ede4d4; margin-bottom: 1.5rem; }
  .modal-tab { flex: 1; padding: 0.65rem; text-align: center; font-weight: 600; font-size: 0.88rem; cursor: pointer; background: #fff; border: none; color: var(--mid); transition: all 0.2s; font-family: 'DM Sans', sans-serif; }
  .modal-tab.active { background: var(--dark); color: var(--gold); }
  .form-group { margin-bottom: 1rem; }
  .form-group label { display: block; font-size: 0.82rem; font-weight: 600; color: var(--mid); margin-bottom: 0.4rem; letter-spacing: 0.04em; text-transform: uppercase; }
  .form-group input { width: 100%; border: 1.5px solid #e8dcc8; border-radius: 8px; padding: 0.75rem 1rem; font-family: 'DM Sans', sans-serif; font-size: 0.92rem; color: var(--dark); outline: none; transition: border-color 0.2s; }
  .form-group input:focus { border-color: var(--gold); }
  .form-error { color: var(--red); font-size: 0.82rem; margin-top: 0.3rem; }
  .form-success { color: var(--green); font-size: 0.85rem; margin-bottom: 1rem; background: #f0fdf4; padding: 0.75rem; border-radius: 8px; border: 1px solid #bbf7d0; }
  .btn-full { width: 100%; padding: 0.9rem; font-size: 0.95rem; border-radius: 8px; }

  /* ── SKELETON LOADERS ── */
  .skeleton { background: linear-gradient(90deg, #f0e8d8 25%, #faf3e0 50%, #f0e8d8 75%); background-size: 200% 100%; animation: shimmer 1.5s infinite; border-radius: 8px; }
  @keyframes shimmer { 0% { background-position: 200% 0; } 100% { background-position: -200% 0; } }
  .skeleton-card { background: #fff; border-radius: 14px; overflow: hidden; border: 1.5px solid #ede4d4; }
  .skeleton-img { height: 130px; }
  .skeleton-body { padding: 1.1rem; }
  .skeleton-line { height: 12px; margin-bottom: 10px; }
  .skeleton-line.short { width: 60%; }
  .skeleton-line.medium { width: 80%; }

  /* ── TOAST ── */
  .toast { position: fixed; bottom: 24px; left: 50%; transform: translateX(-50%); background: var(--dark); color: var(--gold); padding: 0.7rem 1.5rem; border-radius: 8px; font-size: 0.88rem; font-weight: 600; box-shadow: 0 8px 24px rgba(0,0,0,0.3); opacity: 0; pointer-events: none; transition: opacity 0.3s; z-index: 999; border: 1px solid rgba(232,160,32,0.3); white-space: nowrap; }
  .toast.show { opacity: 1; }
  .toast.success { border-color: rgba(0,98,51,0.4); background: var(--green); color: #fff; }
  .toast.error { border-color: rgba(200,16,46,0.4); background: var(--red); color: #fff; }

  /* ── ANIMATIONS ── */
  @keyframes fadeUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }

  /* ── RESPONSIVE ── */
  @media (max-width: 768px) {
    .hero { grid-template-columns: 1fr; gap: 2.5rem; padding: 50px 5vw 60px; }
    .hero::after { display: none; }
    .hero-stats { grid-template-columns: 1fr 1fr; }
    .footer-grid { grid-template-columns: 1fr 1fr; gap: 2rem; }
    .nav-links { display: none; }
  }
</style>
</head>
<body>

<!-- ── NAV ── -->
<nav>
  <div class="logo" onclick="scrollToTop()">Deal<span>na</span></div>
  <ul class="nav-links">
    <li><a onclick="scrollToDeals()">Deals</a></li>
    <li><a onclick="scrollToStores()">Stores</a></li>
    <li><a onclick="scrollToHow()">How it Works</a></li>
    <li id="nav-auth-area">
      <a class="nav-cta" onclick="openModal()">Sign In</a>
    </li>
  </ul>
</nav>

<!-- ── HERO ── -->
<div class="hero">
  <div class="hero-text">
    <div class="hero-badge">🇲🇦 Made for Morocco</div>
    <h1>Save More on<br>Every <em>Purchase</em></h1>
    <p class="hero-sub">Morocco's #1 platform for verified promo codes, exclusive deals, and real savings — from your favorite local and international stores.</p>
    <div class="hero-actions">
      <button class="btn-primary" onclick="scrollToDeals()">Browse Deals</button>
      <button class="btn-secondary" onclick="scrollToHow()">How it Works</button>
    </div>
  </div>
  <div class="hero-stats">
    <div class="stat-card"><div class="num" id="stat-deals">—</div><div class="label">Active Promo Codes</div></div>
    <div class="stat-card"><div class="num" id="stat-stores">—</div><div class="label">Partner Stores</div></div>
    <div class="stat-card"><div class="num">98%</div><div class="label">Verified &amp; Working</div></div>
    <div class="stat-card"><div class="num">50k+</div><div class="label">Happy Savers</div></div>
  </div>
</div>

<!-- ── SEARCH ── -->
<div class="search-bar">
  <div class="search-inner">
    <input id="search-input" type="text" placeholder="Search stores, brands, or promo codes...">
    <button onclick="handleSearch()">Search</button>
  </div>
</div>

<!-- ── CATEGORIES ── -->
<section class="categories">
  <div class="section-header">
    <h2 class="section-title">Shop by <span>Category</span></h2>
  </div>
  <div class="cat-grid" id="cat-grid">
    <div class="skeleton" style="width:100px;height:38px;border-radius:99px"></div>
    <div class="skeleton" style="width:110px;height:38px;border-radius:99px"></div>
    <div class="skeleton" style="width:130px;height:38px;border-radius:99px"></div>
    <div class="skeleton" style="width:100px;height:38px;border-radius:99px"></div>
  </div>
</section>

<!-- ── DEALS ── -->
<section id="deals-section">
  <div class="section-header">
    <h2 class="section-title" id="deals-heading">🔥 Today's <span>Top Deals</span></h2>
    <a class="see-all" onclick="loadMore()">Load more →</a>
  </div>
  <div class="deals-grid" id="deals-grid">
    <!-- skeletons -->
    <div class="skeleton-card"><div class="skeleton skeleton-img"></div><div class="skeleton-body"><div class="skeleton skeleton-line short"></div><div class="skeleton skeleton-line medium"></div><div class="skeleton skeleton-line"></div></div></div>
    <div class="skeleton-card"><div class="skeleton skeleton-img"></div><div class="skeleton-body"><div class="skeleton skeleton-line short"></div><div class="skeleton skeleton-line medium"></div><div class="skeleton skeleton-line"></div></div></div>
    <div class="skeleton-card"><div class="skeleton skeleton-img"></div><div class="skeleton-body"><div class="skeleton skeleton-line short"></div><div class="skeleton skeleton-line medium"></div><div class="skeleton skeleton-line"></div></div></div>
  </div>
  <div class="load-more-wrap" id="load-more-wrap" style="display:none">
    <button class="btn-secondary" id="load-more-btn" onclick="loadMore()">Load more deals</button>
  </div>
</section>

<!-- ── STORES ── -->
