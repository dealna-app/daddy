<div class="toast" id="toast"></div>

<script>
// ════════════════════════════════════════════════════════════════
//  CONFIG — change this to match your running backend
// ════════════════════════════════════════════════════════════════
const API = 'http://localhost:5000/api';

// ── Category emoji map (fallback when API doesn't return icon) ──
const CAT_ICONS = {
  all: '🔥', fashion: '👗', electronics: '📱', home: '🏠',
  beauty: '💄', travel: '✈️', food: '🛵', education: '📚',
  sports: '💪', gaming: '🎮',
};

const STORE_ICONS = {
  jumia:'🛍️', marjane:'🏪', glovo:'🍕', ram:'✈️',
  marwa:'👗', avito:'📦', mytek:'💻', kaymu:'🚗',
};

// ════════════════════════════════════════════════════════════════
//  STATE
// ════════════════════════════════════════════════════════════════
let state = {
  token: localStorage.getItem('dealna_token'),
  user:  JSON.parse(localStorage.getItem('dealna_user') || 'null'),
  currentCategory: 'all',
  currentSearch: '',
  currentPage: 1,
  totalPages: 1,
  savedIds: new Set(),
};

// ════════════════════════════════════════════════════════════════
//  API HELPERS
// ════════════════════════════════════════════════════════════════
async function api(path, opts = {}) {
  const headers = { 'Content-Type': 'application/json' };
  if (state.token) headers['Authorization'] = `Bearer ${state.token}`;
  const res = await fetch(API + path, { headers, ...opts });
  const data = await res.json();
  if (!res.ok) throw new Error(data.error || 'Request failed');
  return data;
}

// ════════════════════════════════════════════════════════════════
//  INIT
// ════════════════════════════════════════════════════════════════
document.addEventListener('DOMContentLoaded', async () => {
  updateNavAuth();
  await Promise.all([loadStats(), loadCategories(), loadDeals(), loadStores()]);
  setupSearch();
  if (state.token) loadSavedIds();
});

// ════════════════════════════════════════════════════════════════
//  STATS
// ════════════════════════════════════════════════════════════════
async function loadStats() {
  try {
    const [dealsData, storesData] = await Promise.all([
      api('/deals?limit=1'),
      api('/stores'),
    ]);
    animateNum('stat-deals', dealsData.pagination?.total || 0);
    animateNum('stat-stores', storesData.stores?.length || 0);
  } catch (_) {}
}

function animateNum(id, target) {
  const el = document.getElementById(id);
  if (!el) return;
  let cur = 0;
  const step = Math.ceil(target / 40);
  const t = setInterval(() => {
    cur = Math.min(cur + step, target);
    el.textContent = cur >= 1000 ? (cur / 1000).toFixed(1) + 'k+' : cur + '+';
    if (cur >= target) clearInterval(t);
  }, 30);
}

// ════════════════════════════════════════════════════════════════
//  CATEGORIES
// ════════════════════════════════════════════════════════════════
async function loadCategories() {
  try {
    const { categories } = await api('/categories');
    const grid = document.getElementById('cat-grid');
    const footerCats = document.getElementById('footer-cats');

    grid.innerHTML = '';
    footerCats.innerHTML = '';

    // "All" chip first
    const allChip = document.createElement('a');
    allChip.className = 'cat-chip active';
    allChip.innerHTML = `<span class="icon">🔥</span> All Deals`;
    allChip.onclick = () => filterCategory('all', allChip);
    grid.appendChild(allChip);

    categories.forEach(cat => {
      if (cat.slug === 'all') return;
      const icon = cat.icon || CAT_ICONS[cat.slug] || '🏷️';

      const chip = document.createElement('a');
      chip.className = 'cat-chip';
      chip.innerHTML = `<span class="icon">${icon}</span> ${cat.name} <span style="color:#c9aa72;font-size:0.75rem">(${cat.deal_count})</span>`;
      chip.onclick = () => filterCategory(cat.slug, chip);
      grid.appendChild(chip);

      // Footer
      const li = document.createElement('li');
      li.innerHTML = `<a onclick="filterCategory('${cat.slug}')" style="cursor:pointer">${cat.name}</a>`;
      footerCats.appendChild(li);
    });
  } catch (_) {}
}

function filterCategory(slug, chipEl) {
  state.currentCategory = slug;
  state.currentSearch = '';
  state.currentPage = 1;
  document.getElementById('search-input').value = '';

  document.querySelectorAll('.cat-chip').forEach(c => c.classList.remove('active'));
  if (chipEl) chipEl.classList.add('active');

  const heading = document.getElementById('deals-heading');
  heading.innerHTML = slug === 'all'
    ? `🔥 Today's <span>Top Deals</span>`
    : `<span>${slug.charAt(0).toUpperCase() + slug.slice(1)}</span> Deals`;

  loadDeals(true);
  scrollToDeals();
}

function filterFeatured() {
  state.currentCategory = 'featured';
  state.currentPage = 1;
  loadDeals(true);
  scrollToDeals();
}

// ════════════════════════════════════════════════════════════════
//  DEALS
// ════════════════════════════════════════════════════════════════
async function loadDeals(reset = false) {
  if (reset) {
    state.currentPage = 1;
    document.getElementById('deals-grid').innerHTML = skeletonCards(3);
    document.getElementById('load-more-wrap').style.display = 'none';
  }

  try {
    const params = new URLSearchParams({ page: state.currentPage, limit: 9 });
    if (state.currentCategory && state.currentCategory !== 'all' && state.currentCategory !== 'featured') {
      params.set('category', state.currentCategory);
    }
    if (state.currentCategory === 'featured') params.set('featured', 'true');
    if (state.currentSearch) params.set('search', state.currentSearch);

    const { deals, pagination } = await api(`/deals?${params}`);
    state.totalPages = pagination.pages;

    const grid = document.getElementById('deals-grid');
    if (reset || state.currentPage === 1) {
      grid.innerHTML = '';
    }

    if (deals.length === 0 && state.currentPage === 1) {
      grid.innerHTML = `<div style="grid-column:1/-1;text-align:center;padding:3rem;color:#9e8e78">
        <div style="font-size:3rem;margin-bottom:1rem">🔍</div>
        <div style="font-weight:600">No deals found</div>
        <div style="font-size:0.9rem;margin-top:0.5rem">Try a different search or category</div>
      </div>`;
    } else {
      deals.forEach(deal => grid.appendChild(buildDealCard(deal)));
      animateCards();
    }

    const wrap = document.getElementById('load-more-wrap');
    const btn  = document.getElementById('load-more-btn');
    if (pagination.page < pagination.pages) {
      wrap.style.display = 'block';
      btn.textContent = 'Load more deals';
      btn.disabled = false;
    } else {
      wrap.style.display = 'none';
    }
  } catch (err) {
    document.getElementById('deals-grid').innerHTML = `<div style="grid-column:1/-1;text-align:center;padding:2rem;color:var(--red)">Failed to load deals. Is the backend running?</div>`;
  }
}

function loadMore() {
  if (state.currentPage >= state.totalPages) return;
  state.currentPage++;
  const btn = document.getElementById('load-more-btn');
  btn.textContent = 'Loading...';
  btn.disabled = true;
  loadDeals(false);
}

function buildDealCard(deal) {
  const div = document.createElement('div');
  div.className = 'deal-card';

  const isSaved    = state.savedIds.has(deal.id);
  const isVerified = deal.is_verified;
  const isFeatured = deal.is_featured;
  const badgeClass = isVerified ? 'verified' : (isFeatured ? 'hot' : '');
  const badgeText  = isVerified ? '✓ Verified' : (isFeatured ? '🔥 HOT' : 'New');

  let expiryHtml = '';
  if (deal.days_left === null || deal.days_left === undefined) {
    expiryHtml = `<div class="expiry"><span class="dot"></span> No expiry</div>`;
  } else if (deal.days_left <= 0) {
    expiryHtml = `<div class="expiry"><span class="dot expired"></span> Expired</div>`;
  } else if (deal.days_left <= 3) {
    expiryHtml = `<div class="expiry"><span class="dot soon"></span> ${deal.days_left}d left</div>`;
  } else {
    expiryHtml = `<div class="expiry"><span class="dot"></span> ${deal.days_left} days left</div>`;
  }

  const icon = deal.category_icon || CAT_ICONS[deal.category_slug] || '🏷️';

  const discountLabel = deal.discount_type === 'percentage' && deal.discount_value
    ? `Save ${deal.discount_value}%`
    : deal.discount_type === 'fixed' && deal.discount_value
      ? `Save ${deal.discount_value} MAD`
      : deal.discount_type === 'free_shipping' ? 'Free Shipping'
      : deal.discount_type === 'bogo' ? 'Buy 1 Get 1'
      : 'Special Deal';

  div.innerHTML = `
    <div class="deal-badge ${badgeClass}">${badgeText}</div>
    <button class="save-btn ${isSaved ? 'saved' : ''}" title="${isSaved ? 'Remove saved' : 'Save deal'}" data-id="${deal.id}" onclick="toggleSave(this, ${deal.id})">
      ${isSaved ? '★' : '☆'}
    </button>
    <div class="deal-img">${icon}</div>
    <div class="deal-body">
      <div class="deal-store">${deal.store_name || ''}</div>
      <div class="deal-title">${deal.title}</div>
      <div class="deal-code-row">
        <div class="deal-code">${deal.code || 'No code needed'}</div>
        <button class="copy-btn" onclick="handleCopy(this, ${deal.id}, '${deal.code || ''}')">Copy</button>
      </div>
      <div class="deal-footer">
        <div class="deal-savings">${discountLabel}</div>
        ${expiryHtml}
      </div>
    </div>`;
  return div;
}

// ════════════════════════════════════════════════════════════════
//  COPY CODE (with API click tracking)
// ════════════════════════════════════════════════════════════════
async function handleCopy(btn, dealId, code) {
  if (code) {
    navigator.clipboard.writeText(code).catch(() => {});
    btn.textContent = 'Copied!';
    btn.classList.add('copied');
    setTimeout(() => { btn.textContent = 'Copy'; btn.classList.remove('copied'); }, 2000);
  }

  try {
    const data = await api(`/deals/${dealId}/click`, { method: 'POST' });
    // If no code, open affiliate URL
    if (!code && data.affiliate_url) window.open(data.affiliate_url, '_blank');
  } catch (_) {}

  showToast(code ? `✓ Code copied: ${code}` : '✓ Deal activated!');
}

// ════════════════════════════════════════════════════════════════
//  SAVE / BOOKMARK
// ════════════════════════════════════════════════════════════════
async function toggleSave(btn, dealId) {
  if (!state.token) { openModal('login'); return; }
  try {
    const { saved } = await api(`/deals/${dealId}/save`, { method: 'POST' });
    if (saved) {
      state.savedIds.add(dealId);
      btn.textContent = '★';
      btn.classList.add('saved');
    } else {
      state.savedIds.delete(dealId);
      btn.textContent = '☆';
      btn.classList.remove('saved');
    }
    showToast(saved ? '★ Deal saved!' : '✕ Removed from saved');
  } catch (_) {
    showToast('Something went wrong', 'error');
  }
}

async function loadSavedIds() {
  try {
    const { deals } = await api('/deals/saved');
    state.savedIds = new Set(deals.map(d => d.id));
  } catch (_) {}
}

async function openSaved() {
  if (!state.token) { openModal('login'); return; }
  try {
    const { deals } = await api('/deals/saved');
    state.currentCategory = 'saved';
    state.currentSearch = '';
    const heading = document.getElementById('deals-heading');
    heading.innerHTML = `★ <span>Saved</span> Deals`;
    const grid = document.getElementById('deals-grid');
    grid.innerHTML = '';
    if (deals.length === 0) {
      grid.innerHTML = `<div style="grid-column:1/-1;text-align:center;padding:3rem;color:#9e8e78"><div style="font-size:3rem;margin-bottom:1rem">☆</div><div style="font-weight:600">No saved deals yet</div></div>`;
    } else {
      deals.forEach(d => grid.appendChild(buildDealCard(d)));
      animateCards();
    }
    scrollToDeals();
  } catch (_) {}
}

// ════════════════════════════════════════════════════════════════
//  STORES
// ════════════════════════════════════════════════════════════════
async function loadStores() {
  try {
    const { stores } = await api('/stores?featured=true');
    const grid = document.getElementById('store-grid');
    grid.innerHTML = '';
    stores.forEach(store => {
      const icon = STORE_ICONS[store.slug] || '🏪';
      const card = document.createElement('a');
      card.className = 'store-card';
      card.innerHTML = `
        <div class="store-icon">${icon}</div>
        <div class="store-name">${store.name}</div>
        <div class="store-count">${store.deal_count} deals</div>`;
      card.onclick = () => filterByStore(store.slug, store.name);
      grid.appendChild(card);
    });
  } catch (_) {}
}

function filterByStore(slug, name) {
  state.currentCategory = 'all';
  state.currentSearch = slug;
  state.currentPage = 1;
  document.getElementById('deals-heading').innerHTML = `🏪 <span>${name}</span> Deals`;
  loadDeals(true);
  scrollToDeals();
}

// ════════════════════════════════════════════════════════════════
//  SEARCH
// ════════════════════════════════════════════════════════════════
function setupSearch() {
  const input = document.getElementById('search-input');
  let timer;
  input.addEventListener('input', () => {
    clearTimeout(timer);
    timer = setTimeout(handleSearch, 450);
  });
  input.addEventListener('keydown', e => { if (e.key === 'Enter') handleSearch(); });
}

function handleSearch() {
  const val = document.getElementById('search-input').value.trim();
  state.currentSearch = val;
  state.currentCategory = 'all';
  state.currentPage = 1;
  document.querySelectorAll('.cat-chip').forEach(c => c.classList.remove('active'));
  document.querySelector('.cat-chip')?.classList.add('active');
  const heading = document.getElementById('deals-heading');
  heading.innerHTML = val
    ? `🔍 Results for <span>"${val}"</span>`
    : `🔥 Today's <span>Top Deals</span>`;
  loadDeals(true);
}

// ════════════════════════════════════════════════════════════════
//  NEWSLETTER
// ════════════════════════════════════════════════════════════════
async function handleSubscribe() {
  const email = document.getElementById('nl-email').value.trim();
  if (!email) return;
  try {
    const data = await api('/newsletter/subscribe', {
      method: 'POST',
      body: JSON.stringify({ email }),
    });
    document.getElementById('nl-email').value = '';
    showToast('🎉 ' + data.message, 'success');
  } catch (err) {
    showToast(err.message, 'error');
  }
}

// ════════════════════════════════════════════════════════════════
//  AUTH MODAL
// ════════════════════════════════════════════════════════════════
function openModal(tab = 'login') {
  document.getElementById('auth-modal').classList.add('open');
  switchTab(tab);
}
function closeModal() {
  document.getElementById('auth-modal').classList.remove('open');
}

document.getElementById('auth-modal').addEventListener('click', e => {
  if (e.target === document.getElementById('auth-modal')) closeModal();
});

function switchTab(tab) {
  ['login','register','forgot'].forEach(t => {
    document.getElementById(`form-${t}`).style.display = 'none';
  });
  document.getElementById(`form-${tab}`).style.display = 'block';
  document.getElementById('modal-success').style.display = 'none';

  document.querySelectorAll('.modal-tab').forEach(t => t.classList.remove('active'));
  if (tab === 'login' || tab === 'forgot') document.getElementById('tab-login').classList.add('active');
  if (tab === 'register') document.getElementById('tab-register').classList.add('active');

  const titles = {
    login: ['Welcome back', 'Sign in to save deals and get personalised alerts.'],
    register: ['Join Dealna 🇲🇦', 'Create your free account and start saving today.'],
    forgot: ['Reset Password', 'Enter your email and we\'ll send a reset link.'],
  };
  document.getElementById('modal-title').textContent = titles[tab][0];
  document.getElementById('modal-subtitle').textContent = titles[tab][1];
}

async function handleLogin() {
  clearErrors();
  const email    = document.getElementById('login-email').value.trim();
  const password = document.getElementById('login-password').value;
  if (!email || !password) return showError('login-err', 'Please fill in all fields');

  try {
    const data = await api('/auth/login', {
      method: 'POST',
      body: JSON.stringify({ email, password }),
    });
    state.token = data.token;
    state.user  = data.user;
    localStorage.setItem('dealna_token', data.token);
    localStorage.setItem('dealna_user', JSON.stringify(data.user));
    closeModal();
    updateNavAuth();
    loadSavedIds();
    showToast(`Welcome back, ${data.user.name}! 🎉`, 'success');
  } catch (err) {
    showError('login-err', err.message);
  }
}

async function handleRegister() {
  clearErrors();
  const name     = document.getElementById('reg-name').value.trim();
  const email    = document.getElementById('reg-email').value.trim();
  const password = document.getElementById('reg-password').value;
  if (!name || !email || !password) return showError('reg-err', 'Please fill in all fields');
  if (password.length < 8) return showError('reg-err', 'Password must be at least 8 characters');

  try {
    const data = await api('/auth/register', {
      method: 'POST',
      body: JSON.stringify({ name, email, password }),
    });
    const s = document.getElementById('modal-success');
    s.textContent = '✅ ' + data.message;
    s.style.display = 'block';
    document.getElementById('form-register').style.display = 'none';
  } catch (err) {
    showError('reg-err', err.message);
  }
}

async function handleForgot() {
  clearErrors();
  const email = document.getElementById('forgot-email').value.trim();
  if (!email) return showError('forgot-err', 'Please enter your email');

  try {
    const data = await api('/auth/forgot-password', {
      method: 'POST',
      body: JSON.stringify({ email }),
    });
    const s = document.getElementById('modal-success');
    s.textContent = '✅ ' + data.message;
    s.style.display = 'block';
    document.getElementById('form-forgot').style.display = 'none';
  } catch (err) {
    showError('forgot-err', err.message);
  }
}

function logout() {
  state.token = null;
  state.user  = null;
  state.savedIds = new Set();
  localStorage.removeItem('dealna_token');
  localStorage.removeItem('dealna_user');
  updateNavAuth();
  showToast('Signed out. See you soon! 👋');
}

function updateNavAuth() {
  const area = document.getElementById('nav-auth-area');
  if (state.user) {
    const initial = state.user.name.charAt(0).toUpperCase();
    area.innerHTML = `
      <div class="nav-user" style="cursor:pointer;position:relative">
        <div class="avatar">${initial}</div>
        <span style="color:var(--cream);font-size:0.85rem">${state.user.name.split(' ')[0]}</span>
        <a onclick="logout()" style="color:#9e8e78;font-size:0.8rem;margin-left:0.5rem">(Sign out)</a>
      </div>`;
  } else {
    area.innerHTML = `<a class="nav-cta" onclick="openModal()">Sign In</a>`;
  }
}

// ════════════════════════════════════════════════════════════════
//  HELPERS
// ════════════════════════════════════════════════════════════════
function showToast(msg, type = '') {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.className = `toast ${type} show`;
  setTimeout(() => t.className = 'toast', 3000);
}

function showError(id, msg) {
  const el = document.getElementById(id);
  if (el) el.textContent = msg;
}

function clearErrors() {
  document.querySelectorAll('.form-error').forEach(e => e.textContent = '');
  document.getElementById('modal-success').style.display = 'none';
}

function skeletonCards(n) {
  return Array(n).fill(`
    <div class="skeleton-card">
      <div class="skeleton skeleton-img"></div>
      <div class="skeleton-body">
        <div class="skeleton skeleton-line short"></div>
        <div class="skeleton skeleton-line medium"></div>
        <div class="skeleton skeleton-line"></div>
      </div>
    </div>`).join('');
}

function animateCards() {
  document.querySelectorAll('.deal-card').forEach((el, i) => {
    el.style.opacity = '0';
    el.style.transform = 'translateY(16px)';
    setTimeout(() => {
      el.style.transition = 'opacity 0.4s ease, transform 0.4s ease';
      el.style.opacity = '1';
      el.style.transform = 'translateY(0)';
    }, i * 60);
  });
}

function scrollToTop()    { window.scrollTo({ top: 0, behavior: 'smooth' }); }
function scrollToDeals()  { document.getElementById('deals-section').scrollIntoView({ behavior: 'smooth' }); }
function scrollToStores() { document.getElementById('stores-section').scrollIntoView({ behavior: 'smooth' }); }
function scrollToHow()    { document.getElementById('how-section').scrollIntoView({ behavior: 'smooth' }); }

// Scroll animations
const observer = new IntersectionObserver(entries => {
  entries.forEach(entry => {
    if (entry.isIntersecting) {
      entry.target.style.animation = 'fadeUp 0.5s ease both';
      observer.unobserve(entry.target);
    }
  });
}, { threshold: 0.1 });

document.querySelectorAll('.how-step, .stat-card').forEach(el => {
  el.style.opacity = '0';
  observer.observe(el);
});
</script>
